{
  "name": "zentsu.app",
  "version": "1.0.0",
  "main": "nav.js",
  "scripts": {
    "build": "bundle exec jekyll build",
    "validate:html": "html-validate '_site/**/*.html'",
    "validate:links": "test -f _site/bench.html && rg -q 'id=\"pricing\"' _site/bench.html && linkinator _site --recurse --clean-urls --check-fragments --check-css --skip '/bench(#.*)?$' --skip 'mailto:' --skip 'cdn-cgi'",
    "test": "npm run build && npm run validate:html && npm run validate:links"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomtclai/zentsu.app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tomtclai/zentsu.app/issues"
  },
  "homepage": "https://github.com/tomtclai/zentsu.app#readme",
  "description": "",
  "devDependencies": {
    "html-validate": "^10.11.3",
    "lefthook": "^2.1.6",
    "linkinator": "^7.6.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5"
  }
}
